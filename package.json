{
  "name": "luckydraw-grouper",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A versatile tool for prize draws with animations and automatic group partitioning from CSV or text sources.",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
